# =====================================================
# DevPilot AI Backend
# Production Dockerfile
# =====================================================

FROM node:22-alpine

# =====================================================
# Working Directory
# =====================================================

WORKDIR /app

# =====================================================
# Copy Package Files
# =====================================================

COPY package*.json ./

# =====================================================
# Install Production Dependencies
# =====================================================

RUN npm ci --omit=dev

# =====================================================
# Copy Project
# =====================================================

COPY . .

# =====================================================
# Environment
# =====================================================

ENV NODE_ENV=production

# =====================================================
# Expose API Port
# =====================================================

EXPOSE 5000

# =====================================================
# Start Server
# =====================================================

CMD ["npm", "start"]